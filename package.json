{
  "name": "spinybacked-orbweaver",
  "version": "0.1.0",
  "description": "AI-powered telemetry instrumentation agent for JavaScript applications",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "orb": "bin/orb.js"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "prepare": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wiggitywhitney/spinybacked-orbweaver.git"
  },
  "keywords": [
    "opentelemetry",
    "telemetry",
    "instrumentation",
    "ai-agent"
  ],
  "author": "Whitney Lee",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/wiggitywhitney/spinybacked-orbweaver/issues"
  },
  "homepage": "https://github.com/wiggitywhitney/spinybacked-orbweaver#readme",
  "devDependencies": {
    "@types/node": "^24.11.0",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "prettier": "^3.8.1",
    "simple-git": "^3.33.0",
    "ts-morph": "^27.0.2",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  }
}
